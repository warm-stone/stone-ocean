pipeline {
    agent  any

    environment {
        DATASOURCE_URL = credentials('warm-stone-datasource-url')
        FILE_PATH = credentials('warm-stone-file-path')
        DATASOURCE = credentials('warm-stone-datasource-password')
        GITHUB = credentials('https-vote-warm-stone')
        ALI_HOST_IP = credentials('ali-host-ip')
        IMAGE_NAME = 'stone-ocean'
        VERSION = '0.0.1-SNAPSHOT'
    }

    stages {
        stage('Build') {
            steps {
                echo '开始构建项目：编译并打包 JAR'
                // 先添加执行权限
                sh 'chmod +x ./gradlew'
                // 使用 Gradle Wrapper 构建（推荐），或直接使用 gradle 命令
                // -x test 表示跳过测试（测试在下一阶段单独运行）
                sh './gradlew build -x test --no-daemon'
            }
        }

        stage('Test') {
            steps {
                withCredentials([
                    file(credentialsId: 'warm-stone-jwt-key', variable: 'JWT_KEY'),
                    file(credentialsId: 'warm-stone-jwt-pub', variable: 'JWT_PUB')
                ]) {
                    echo '运行单元测试'
                    pwd()
                    sh 'ls -al'
                    echo 'jwt pub:'
                    sh "echo $JWT_PUB"
                    sh """
                        mkdir -p src/main/resources/keyPair
                        cp  \${JWT_KEY} src/main/resources/keyPair/app.key
                        cp  \${JWT_PUB} src/main/resources/keyPair/app.pub
                    """
                    sh './gradlew test --no-daemon'
                }
            }
            post {
                always {
                    // 收集测试报告
                    // Gradle 默认生成 XML 报告在 build/test-results/test/
                    // Jenkins JUnit 插件可解析这些文件
                    junit 'build/test-results/test/*.xml'
                }
            }
        }

        stage('Deploy') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'https-vote-warm-stone',
                        usernameVariable: 'GITHUB_CLIENT_ID',
                        passwordVariable: 'GITHUB_CLIENT_SECRET'
                    )
                ]) {
                    echo '交付应用：运行发布脚本'
                    sh 'chmod +x ./jenkins/scripts/run_container.sh'
                    sh './jenkins/scripts/run_container.sh '
                    // 生成运行时环境变量文件（含密钥），仅用于远程容器运行时注入；用完即删
                    // 使用单引号三引串：Groovy 不插值，由 shell 展开 $VAR；set +x 防止命令回显泄漏密钥
                    sh '''
                        set +x
                        umask 077
                        cat > app.env <<EOF
DATASOURCE_URL=$DATASOURCE_URL
DATASOURCE_USR=$DATASOURCE_USR
DATASOURCE_PSW=$DATASOURCE_PSW
GITHUB_CLIENT_ID=$GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=$GITHUB_CLIENT_SECRET
FILE_PATH=$FILE_PATH
EOF
                    '''
               }
               withCredentials([sshUserPrivateKey(credentialsId: 'ali-appuser', keyFileVariable: 'SSH_KEY', usernameVariable: 'USERNAME')]) {
                   // 打包镜像
                   sh "docker save -o ${IMAGE_NAME}.tar ${IMAGE_NAME}"
                   // SCP 传到目标服务器
                   sshPut(
                       remote: [ name: 'ali-server', host: ALI_HOST_IP, user: USERNAME,  identityFile: SSH_KEY, allowAnyHosts: true],
                       from: "${IMAGE_NAME}.tar",
                       into: "./stone-ocean/"
                   )
                   // SCP 运行时环境变量文件到目标服务器（密钥不进镜像层，仅运行时注入）
                   sshPut(
                       remote: [ name: 'ali-server', host: ALI_HOST_IP, user: USERNAME,  identityFile: SSH_KEY, allowAnyHosts: true],
                       from: "app.env",
                       into: "./stone-ocean/"
                   )
                   // 远程加载并启动（密钥通过 env-file 运行时注入，运行后立即删除）
                   sshCommand(
                       remote: [ name: 'ali-server', host: ALI_HOST_IP, user: USERNAME,  identityFile: SSH_KEY, allowAnyHosts: true],
                       command: """
                           cd ./stone-ocean/
                           chmod 600 app.env
                           echo "输出测试"
                           echo $VERSION
                           docker load -i ${IMAGE_NAME}.tar
                           docker stop $IMAGE_NAME || true
                           docker rm $IMAGE_NAME || true
                           docker run -d --name "$IMAGE_NAME" -p 8101:8101 -v $FILE_PATH:$FILE_PATH --restart unless-stopped --env-file app.env $IMAGE_NAME:$VERSION
                           rm -f app.env
                       """
                   )
               }

            }
            post {
                always {
                    // 部署成功或失败均清理 Jenkins 侧含密钥的临时环境变量文件
                    sh 'rm -f app.env'
                }
            }
        }
    }
}